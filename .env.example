# App

# Mode of the application.
# Test mode is used for testing and development, while production mode is used for deployment.
# Test mode will appear more logs needed for debugging in server console.
# Production mode will have less logging and more security and optimization
APP_MODE=DEV
# Port of the application.
# Use it to prevent the ports on your server from matching
APP_PORT=8080
# Mode of SQL debugger
BUNDEBUG=2

# Database

# Database user created especially for this application.
# DO NOT USE YOUR ROOT USER FOR THIS APPLICATION, IT CAN CAUSE SECURITY ISSUES AND DATA LOSS.
DB_USER=
# Password of database user. Make sure to use a strong password and do not share it with anyone.
DB_PASSWORD=
# Host of the database server.
# If you are running the database server on the same machine as the application, you can use localhost or 127.0.0.1
DB_HOST=
# Port of the database server. The default port for MySQL is 3306, but it can be different if you have changed it during installation.
DB_PORT=
# Name of table on the database server
DB_NAME=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Auth

# Secret key used for signing JWT tokens. Make sure to use a strong and unique secret key and do not share it with anyone.
JWT_SECRET=

# OAuth

# Discord is used to link user accounts with discord accounts and to allow users to login with their discord accounts.
# You can make a discord application on Discord Developer Portal https://discord.com/developers/applications

# Client ID of the discord application. You can find it on the General Information page of your discord application.
DISCORD_CLIENT_ID=
# Client Secret of the discord application. You can find it on the Bot page of your discord application.
# Make sure to keep it secret and do not share it with anyone.
DISCORD_CLIENT_SECRET=
# Redirect URI is the URL where the user will be redirected after he linked his discord account on your local machine with APP_MODE = test.
DISCORD_LOCAL_REDIRECT_URI=
# Redirect URI is the URL where the user will be redirected after he linked his discord account on your production machine with APP_MODE = production.
DISCORD_PRODUCTION_REDIRECT_URI=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=