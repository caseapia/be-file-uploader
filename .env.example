# Application
APP_MODE=DEV
APP_PORT=8080

# Database
DB_USER=VALUE
DB_PASSWORD=VALUE
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fileuploader

# Authentication
JWT_SECRET=CHANGE_ME

# Object storage
# Exact key names are currently case-sensitive because the app reads them as shown here.
R2_ACCESS_KEY=VALUE
R2_SECRET_KEY=VALUE
R2_BUCKET=VALUE
R2_PUBLIC_URL=https://cdn.example.com

# Reserved OAuth configuration
DISCORD_CLIENT_ID=VALUE
DISCORD_CLIENT_SECRET=VALUE
DISCORD_LOCAL_REDIRECT_URI=http://localhost:3000/callback
DISCORD_PRODUCTION_REDIRECT_URI=https://example.com/callback
