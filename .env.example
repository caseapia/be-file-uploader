# Application
APP_MODE=DEV
APP_PORT=VALUE

# Database
DB_USER=VALUE
DB_PASSWORD=VALUE
DB_HOST=VALUE
DB_PORT=VALUE
DB_NAME=VALUE
REDIS_HOST=VALUE
REDIS_PORT=VALUE
REDIS_PASSWORD=VALUE

# Authentication
JWT_SECRET=CHANGE_ME

# Object storage
