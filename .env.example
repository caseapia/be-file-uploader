R2_PUBLIC_URL=VALUE

# Reserved OAuth configuration
DISCORD_CLIENT_ID=VALUE
DISCORD_CLIENT_SECRET=VALUE
DISCORD_LOCAL_REDIRECT_URI=VALUE
DISCORD_PRODUCTION_REDIRECT_URI=VALUE
